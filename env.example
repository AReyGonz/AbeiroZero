# Copia este archivo como .env y rellena con tus credenciales reales.
# NUNCA subas el archivo .env real al repositorio.

# Copernicus Data Space Ecosystem (CDSE)
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=

# MeteoGalicia (la API REST no requiere key, pero se deja por si en el
# futuro se usa algún servicio que sí la requiera)
METEOGALICIA_API_KEY=

# AEMET OpenData (si se llega a usar)
AEMET_API_KEY=
